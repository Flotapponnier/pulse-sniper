    {"type":"text","version":1,"versionNonce":301,"isDeleted":false,"id":"box-mobula-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":396,"y":146,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":228,"height":120,"seed":301,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":17,"fontFamily":3,"text":"Mobula Pulse Stream V2\nwss://api.mobula.io\n\nIndexes every fresh\nlaunch in real time.\nServer-side filters.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"mobula","autoResize":true,"lineHeight":1.25},

