    {"type":"text","version":1,"versionNonce":1101,"isDeleted":false,"id":"mod-2-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":376,"y":376,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":268,"height":130,"seed":1101,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":15,"fontFamily":3,"text":"2. SeenStore\ncore/seen-store.ts\n\nSQLite (better-sqlite3).\nKey: chainId|address.\nInit/sync seed it silently.\nGuarantees one alert per token.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"2. SeenStore\ncore/seen-store.ts\n\nSQLite (better-sqlite3).\nKey: chainId|address.\nInit/sync seed it silently.\nGuarantees one alert per token.","autoResize":true,"lineHeight":1.25},

