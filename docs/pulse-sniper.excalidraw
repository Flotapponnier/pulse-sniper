    {"type":"text","version":1,"versionNonce":14,"isDeleted":false,"id":"text-sub","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":52,"y":310,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":280,"height":320,"seed":14,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":1,"text":"Subscribe payload (server-side filters)\n{\n  type: 'pulse-v2',\n  authorization: <KEY>,\n  payload: {\n    chainId: ['solana:solana','evm:8453','evm:1'],\n    poolTypes: ['pumpfun','raydium-v4',\n                'uniswap-v2','uniswap-v3'],\n    views: [{\n      name: 'fresh-tokens',\n      sortBy: 'created_at',\n      filters: {\n        created_at_offset: { lte: 60 },\n        liquidity: { gte: 2000 },\n        bonded: { equals: false },\n        dev_holdings_percentage: { lte: 15 },\n        snipers_holdings_percentage: { lte: 20 },\n        top_10_holdings_percentage: { lte: 70 },\n        security: {\n          isBlacklisted: { equals: false },\n          buyTax: { lte: 5 }, sellTax: { lte: 10 }\n        }\n      }\n    }]\n  }\n}","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Subscribe payload (server-side filters)","autoResize":true,"lineHeight":1.25},

