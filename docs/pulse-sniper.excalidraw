    {"type":"arrow","version":1,"versionNonce":800,"isDeleted":false,"id":"arr-3","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":1000,"y":205,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":40,"height":0,"seed":800,"groupIds":[],"frameId":null,"roundness":{"type":2},"boundElements":[],"updated":1,"link":null,"locked":false,"startBinding":null,"endBinding":null,"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[40,0]]},

    {"type":"text","version":1,"versionNonce":900,"isDeleted":false,"id":"section-1","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":40,"y":320,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":900,"height":32,"seed":900,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":24,"fontFamily":3,"text":"Decision pipeline — when do we alert?","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"sec1","autoResize":true,"lineHeight":1.25},
    {"type":"text","version":1,"versionNonce":901,"isDeleted":false,"id":"section-1-sub","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":40,"y":355,"strokeColor":"#5c5c5c","backgroundColor":"transparent","width":1200,"height":22,"seed":901,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":15,"fontFamily":3,"text":"Each new-token event walks down 4 stages. First failure exits silently. Only stage 4 produces a Telegram message.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"sec1sub","autoResize":true,"lineHeight":1.25},

    {"type":"rectangle","version":1,"versionNonce":1000,"isDeleted":false,"id":"stage-1","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":40,"y":390,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","width":290,"height":250,"seed":1000,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1,"link":null,"locked":false},
    {"type":"text","version":1,"versionNonce":1001,"isDeleted":false,"id":"stage-1-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":56,"y":404,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":258,"height":230,"seed":1001,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"STAGE 1 — Server filter\n(at Mobula, before send)\n\nIn the subscribe payload:\n\n  filters: {\n    liquidity: { gte: 2000 },\n    bonded:    { equals: false }\n  }\n\nMobula only pushes tokens that\nalready pass these. Nothing under\n$2k of liquidity hits our wire,\nand bonded pumpfun tokens (already\nmigrated) are skipped.\n\nWhy: saves bandwidth and gives\nMobula a chance to apply native\nindexer-side optimizations.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"s1","autoResize":true,"lineHeight":1.25},

    {"type":"rectangle","version":1,"versionNonce":1100,"isDeleted":false,"id":"stage-2","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":350,"y":390,"strokeColor":"#0ca678","backgroundColor":"#c3fae8","width":290,"height":250,"seed":1100,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1,"link":null,"locked":false},
    {"type":"text","version":1,"versionNonce":1101,"isDeleted":false,"id":"stage-2-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":366,"y":404,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":258,"height":230,"seed":1101,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"STAGE 2 — Dedup\n(SeenStore, SQLite)\n\nKey:  chainId|address.toLowerCase()\n\nIf already seen → return silently.\nElse → mark seen, continue.\n\nInit and sync events seed this\ntable WITHOUT alerting, so the\n50 tokens currently in the view\nat boot time are remembered as\n'already seen' and never trigger\na message.\n\nWhy: sync replays the full view\nevery ~30s. Without dedup, every\ntoken would re-fire forever.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"s2","autoResize":true,"lineHeight":1.25},

    {"type":"rectangle","version":1,"versionNonce":1200,"isDeleted":false,"id":"stage-3","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":660,"y":390,"strokeColor":"#c92a2a","backgroundColor":"#ffe3e3","width":290,"height":250,"seed":1200,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1,"link":null,"locked":false},
    {"type":"text","version":1,"versionNonce":1201,"isDeleted":false,"id":"stage-3-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":676,"y":404,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":258,"height":230,"seed":1201,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"STAGE 3 — Reject gates\n(QualityGate.evaluate)\n\nFirst failure exits.\n\n1. address + chainId present\n2. symbol non-empty\n3. is_spam !== true\n4. createdAt parsable\n5. age ≤ MAX_AGE_SECONDS  (60s)\n6. age not in the future (>−10s)\n7. bonded !== true\n8. liquidity ≥ MIN_LIQUIDITY_USD\n9. devHoldings ≤ 15%\n10. snipersHoldings ≤ 20%\n11. top10Holdings ≤ 70%\n\nWhy these caps:\n  dev > 15% = easy rugpull\n  snipers > 20% = bots will dump\n  top10 > 70% = supply too concentrated","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"s3","autoResize":true,"lineHeight":1.25},

    {"type":"rectangle","version":1,"versionNonce":1300,"isDeleted":false,"id":"stage-4","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":970,"y":390,"strokeColor":"#5f3dc4","backgroundColor":"#e5dbff","width":290,"height":250,"seed":1300,"groupIds":[],"frameId":null,"roundness":{"type":3},"boundElements":[],"updated":1,"link":null,"locked":false},
    {"type":"text","version":1,"versionNonce":1301,"isDeleted":false,"id":"stage-4-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":986,"y":404,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":258,"height":230,"seed":1301,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"STAGE 4 — Score & send\n\nIf all gates pass → score 0-100,\nformat MarkdownV2, send.\n\nThe score does NOT filter — a\n50/100 token still gets its alert.\nIt only labels the message visually\nso you can prioritize when several\nalerts land at once.\n\nBuckets:\n  ≥ 80   ELITE\n  ≥ 60   GOOD\n  ≥ 40   FAIR\n  < 40   LOW\n\nThen bot.telegram.sendMessage\nwith inline_keyboard:\n  Chart  ·  Trade on …\n(per-chain DEX URL)","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"s4","autoResize":true,"lineHeight":1.25},

    {"type":"arrow","version":1,"versionNonce":1310,"isDeleted":false,"id":"arr-s12","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":330,"y":515,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":20,"height":0,"seed":1310,"groupIds":[],"frameId":null,"roundness":{"type":2},"boundElements":[],"updated":1,"link":null,"locked":false,"startBinding":null,"endBinding":null,"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[20,0]]},
