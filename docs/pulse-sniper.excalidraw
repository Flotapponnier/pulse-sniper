    {"type":"text","version":1,"versionNonce":401,"isDeleted":false,"id":"box-bot-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":736,"y":146,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":248,"height":120,"seed":401,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":17,"fontFamily":3,"text":"pulse-sniper (Node.js)\n\n4 modules · ~600 LOC\nNo infra, no DB server,\nno polling, no cron.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"bot","autoResize":true,"lineHeight":1.25},

