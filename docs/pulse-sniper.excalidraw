    {"type":"text","version":1,"versionNonce":201,"isDeleted":false,"id":"box-dexs-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":56,"y":146,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":228,"height":120,"seed":201,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":17,"fontFamily":3,"text":"Source\nDEXs (on-chain)\n\npump.fun · Raydium\nMoonshot · Uniswap\nSolana · Base · ETH","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"src","autoResize":true,"lineHeight":1.25},

