    {"type":"text","version":1,"versionNonce":501,"isDeleted":false,"id":"box-tg-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":1056,"y":146,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":188,"height":120,"seed":501,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":17,"fontFamily":3,"text":"Telegram\n@pulser_snip_bot\n\nMarkdownV2 alert\n+ Chart / Buy buttons","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"tg","autoResize":true,"lineHeight":1.25},

