    {"type":"text","version":1,"versionNonce":1201,"isDeleted":false,"id":"mod-3-text","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":696,"y":376,"strokeColor":"#1e1e1e","backgroundColor":"transparent","width":268,"height":130,"seed":1201,"groupIds":[],"frameId":null,"roundness":null,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":15,"fontFamily":3,"text":"3. QualityGate\ncore/quality-gate.ts\n\nClient-side double-check.\nReject: bonded, low liq,\nhigh dev/snipers/top10.\nScore 0-100 → ELITE/GOOD/FAIR/LOW","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3. QualityGate\ncore/quality-gate.ts\n\nClient-side double-check.\nReject: bonded, low liq,\nhigh dev/snipers/top10.\nScore 0-100 → ELITE/GOOD/FAIR/LOW","autoResize":true,"lineHeight":1.25},

