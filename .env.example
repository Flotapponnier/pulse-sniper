# Mobula API key — get one at https://mobula.io
MOBULA_API_KEY=mob_xxxxxxxxxxxxxxxxxxxxxxxx

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxx

# Target chat (group or DM). Use @userinfobot to get your chat id.
TELEGRAM_CHAT_ID=123456789

# Comma-separated chains to subscribe to (Mobula format: <ecosystem>:<id>)
WATCH_CHAINS=solana:solana,evm:8453,evm:1

# Comma-separated DEX pool types
WATCH_POOL_TYPES=pumpfun,moonshot-evm,raydium-v4,uniswap-v2,uniswap-v3

# Quality gate thresholds
MAX_AGE_SECONDS=60
MIN_LIQUIDITY_USD=2000
MAX_DEV_HOLDINGS=15
MAX_SNIPERS_HOLDINGS=20
MAX_TOP10_HOLDINGS=70
MAX_BUY_TAX=5
MAX_SELL_TAX=10

# Storage and logging
DB_PATH=./bot.db
LOG_LEVEL=info
